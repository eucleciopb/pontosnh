# Supabase (obtenha em: https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon (JWT eyJ...) ou publishable (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Alternativa ao nome acima (mesmo valor):
# VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publishable

# Nunca exponha a Service Role Key no frontend!
# SUPABASE_SERVICE_ROLE_KEY=use-apenas-em-backend-ou-edge-functions

# Totem — vídeo de repouso (quando ninguém mexe na tela)
# Coloque o arquivo em public/videos/totem-idle.mp4 ou use URL externa:
# VITE_TOTEM_IDLE_VIDEO_URL=/videos/totem-idle.mp4
# Tempo de inatividade em segundos antes do vídeo (padrão: 60)
# VITE_TOTEM_IDLE_SECONDS=60
